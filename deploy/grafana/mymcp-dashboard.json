{
  "title": "mymcp MCP Server",
  "uid": "mymcp-dashboard",
  "schemaVersion": 38,
  "version": 1,
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "refresh": "30s",
  "tags": [
    "mymcp"
  ],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "label": "Prometheus",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0,
        "refresh": 1,
        "includeAll": false,
        "multi": false
      },
      {
        "name": "instance",
        "label": "Instance",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "query": {
          "query": "label_values(up{job=~\"mymcp.*\"}, instance)",
          "refId": "A"
        },
        "refresh": 2,
        "sort": 1,
        "includeAll": true,
        "allValue": ".*",
        "multi": false,
        "current": {},
        "hide": 0
      }
    ]
  },
  "annotations": {
    "list": []
  },
  "links": [],
  "editable": true,
  "graphTooltip": 1,
  "style": "dark",
  "timezone": "browser",
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Overview Stats",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Tool Calls",
      "description": "Total mymcp_tool_calls_total over the selected time range (uses Grafana's $__range, follows the time picker). MCP handshake/listTools traffic is NOT counted - this is dispatched tool invocations only.",
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(mymcp_tool_calls_total{job=~\"mymcp.*\",instance=~\"$instance\"}[$__range]))",
          "legendFormat": "Total Calls"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Tool Error Rate",
      "description": "Share of mymcp_tool_calls_total with result=\"error\" over the last 5 minutes. Threshold turns red above 5%. HTTP 4xx/5xx are not part of this; see HTTP panels for that.",
      "gridPos": {
        "x": 6,
        "y": 1,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(mymcp_tool_calls_total{job=~\"mymcp.*\",instance=~\"$instance\",result=\"error\"}[5m])) / sum(rate(mymcp_tool_calls_total{job=~\"mymcp.*\",instance=~\"$instance\"}[5m])) * 100 or vector(0)",
          "legendFormat": "Error Rate %"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Tool p95 Latency",
      "description": "p95 of mymcp_tool_duration_seconds across all tools (5m window). Threshold turns red above 1000 ms. This is dispatch+execution time only, not HTTP RTT.",
      "gridPos": {
        "x": 12,
        "y": 1,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1000
              }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum(rate(mymcp_tool_duration_seconds_bucket{job=~\"mymcp.*\",instance=~\"$instance\"}[5m])) by (le)) * 1000",
          "legendFormat": "p95 ms"
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Service Status",
      "description": "Prometheus up{} per instance. UP=1, DOWN=0. With Instance=All, every instance renders as its own block.",
      "gridPos": {
        "x": 18,
        "y": 1,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value_and_name",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "DOWN",
                  "color": "red"
                },
                "1": {
                  "text": "UP",
                  "color": "green"
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "up{job=~\"mymcp.*\",instance=~\"$instance\"}",
          "legendFormat": "{{instance}}"
        }
      ]
    },
    {
      "id": 10,
      "type": "row",
      "title": "Tool Call Rate",
      "gridPos": {
        "x": 0,
        "y": 5,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Tool Call Rate",
      "description": "Per-tool call rate split by result (ok / error). Errors render red; ok renders green.",
      "gridPos": {
        "x": 0,
        "y": 6,
        "w": 24,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": false
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byRegexp",
              "options": ".*error.*"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "red",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
              "options": ".*ok.*"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "green",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(mymcp_tool_calls_total{job=~\"mymcp.*\",instance=~\"$instance\"}[5m])) by (tool, result)",
          "legendFormat": "{{tool}} - {{result}}"
        }
      ]
    },
    {
      "id": 20,
      "type": "row",
      "title": "Latency Percentiles",
      "gridPos": {
        "x": 0,
        "y": 14,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "Tool Latency Percentiles",
      "description": "p50 / p95 / p99 of mymcp_tool_duration_seconds_bucket per tool, derived from histogram_quantile over a 5m window.",
      "gridPos": {
        "x": 0,
        "y": 15,
        "w": 24,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 5,
            "spanNulls": false
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.50, sum(rate(mymcp_tool_duration_seconds_bucket{job=~\"mymcp.*\",instance=~\"$instance\"}[5m])) by (le, tool))",
          "legendFormat": "p50 {{tool}}"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum(rate(mymcp_tool_duration_seconds_bucket{job=~\"mymcp.*\",instance=~\"$instance\"}[5m])) by (le, tool))",
          "legendFormat": "p95 {{tool}}"
        },
        {
          "refId": "C",
          "expr": "histogram_quantile(0.99, sum(rate(mymcp_tool_duration_seconds_bucket{job=~\"mymcp.*\",instance=~\"$instance\"}[5m])) by (le, tool))",
          "legendFormat": "p99 {{tool}}"
        }
      ]
    },
    {
      "id": 30,
      "type": "row",
      "title": "HTTP Requests",
      "gridPos": {
        "x": 0,
        "y": 23,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "id": 31,
      "type": "timeseries",
      "title": "HTTP Request Rate by Path & Status",
      "description": "Request rate by method, path, and HTTP status. High-cardinality paths can blow up Prometheus memory; keep request paths bounded server-side.",
      "gridPos": {
        "x": 0,
        "y": 24,
        "w": 24,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": false
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(mymcp_http_requests_total{job=~\"mymcp.*\",instance=~\"$instance\"}[5m])) by (method, path, status)",
          "legendFormat": "{{method}} {{path}} {{status}}"
        }
      ]
    },
    {
      "id": 40,
      "type": "row",
      "title": "Process Health",
      "gridPos": {
        "x": 0,
        "y": 32,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "id": 41,
      "type": "timeseries",
      "title": "RSS Memory",
      "description": "Resident memory of the mymcp process (process_resident_memory_bytes from prometheus_client).",
      "gridPos": {
        "x": 0,
        "y": 33,
        "w": 8,
        "h": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "options": {
        "tooltip": {
          "mode": "single",
          "sort": "none"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": false
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "process_resident_memory_bytes{job=~\"mymcp.*\",instance=~\"$instance\"}",
          "legendFormat": "RSS {{instance}}"
        }
      ]
    },
    {
      "id": 42,
      "type": "timeseries",
      "title": "CPU Usage",
      "description": "CPU utilization of the mymcp process, computed as rate(process_cpu_seconds_total[5m]) * 100.",
      "gridPos": {
        "x": 8,
        "y": 33,
        "w": 8,
        "h": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "options": {
        "tooltip": {
          "mode": "single",
          "sort": "none"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": false
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(process_cpu_seconds_total{job=~\"mymcp.*\",instance=~\"$instance\"}[5m]) * 100",
          "legendFormat": "CPU {{instance}}"
        }
      ]
    },
    {
      "id": 43,
      "type": "timeseries",
      "title": "Open File Descriptors",
      "description": "process_open_fds for the mymcp process. Watch this against the process's RLIMIT_NOFILE.",
      "gridPos": {
        "x": 16,
        "y": 33,
        "w": 8,
        "h": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "options": {
        "tooltip": {
          "mode": "single",
          "sort": "none"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": false
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "process_open_fds{job=~\"mymcp.*\",instance=~\"$instance\"}",
          "legendFormat": "FDs {{instance}}"
        }
      ]
    }
  ]
}
